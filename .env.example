# kbagent configuration — copy to .env and fill in values

# ── Daemon settings ───────────────────────────────────────────────────────────

# Absolute path to the project repo on the host machine.
KB_AGENT_REPO_PATH=/Users/you/projects/my-project

# Directory where per-ticket git worktrees will be created.
KB_AGENT_WORKTREES_DIR=/Users/you/projects/my-project-worktrees

# Log file path.
KB_AGENT_LOG_FILE=/Users/you/Library/Logs/kbagent.log

# Ticket provider (currently only "plane" is supported).
KB_AGENT_TICKET_PROVIDER=plane

# Max claude turns per agent session before the assessor kicks in.
KB_AGENT_MAX_TURNS=50

# Seconds to sleep when the queue is empty.
KB_AGENT_SLEEP_NO_WORK=15

# Seconds to sleep after an unexpected error.
KB_AGENT_SLEEP_ERROR=300

# Optional: shell command the agent must run before opening a PR.
# If set, the agent prompt will include "Run `<cmd>` — do not open a PR if it fails".
# Examples: "go build ./..."  or  "cd frontend && npx tsc --noEmit"
KB_AGENT_VALIDATE_CMD=

# ── Plane provider ────────────────────────────────────────────────────────────

KB_AGENT_PLANE_BASE_URL=https://api.plane.so
KB_AGENT_PLANE_WORKSPACE_SLUG=my-workspace
KB_AGENT_PLANE_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# State UUIDs — find these via:
#   GET /api/v1/workspaces/<slug>/projects/<id>/states/
# Create "Spec Approved" (group: unstarted) and "Needs Input" (group: started) states in Plane.
KB_AGENT_PLANE_STATE_BACKLOG=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
KB_AGENT_PLANE_STATE_SPEC_APPROVED=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
KB_AGENT_PLANE_STATE_IN_PROGRESS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
KB_AGENT_PLANE_STATE_NEEDS_INPUT=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
KB_AGENT_PLANE_STATE_IN_REVIEW=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Credentials ───────────────────────────────────────────────────────────────

KB_AGENT_PLANE_API_KEY=your-plane-api-key
KB_AGENT_GITHUB_TOKEN=ghp_your-github-token
KB_AGENT_CLAUDE_CODE_OAUTH_TOKEN=your-claude-oauth-token

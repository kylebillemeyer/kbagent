[daemon]
# Absolute path to the project repo on the host machine.
repo_path = "/Users/you/projects/my-project"

# Directory where per-ticket git worktrees will be created.
worktrees_dir = "/Users/you/projects/my-project-worktrees"

# Docker image name for the agent container.
docker_image = "my-project-agent"

# Path to the Dockerfile used by `kbagent build`. Relative to repo_path or absolute.
# Required to use `kbagent build` — no default.
dockerfile = "path/to/Dockerfile"

# Log file path.
log_file = "/Users/you/Library/Logs/kbagent.log"

# Ticket provider: "github" or "plane"
ticket_provider = "plane"

# Max claude turns per agent session before the assessor kicks in.
max_turns = 50

# Seconds to sleep when the queue is empty.
sleep_no_work = 15

# Seconds to sleep after an unexpected error.
sleep_error = 300

# macOS Keychain service name used to look up secrets.
# Store secrets with: security add-generic-password -a <account> -s <keychain_service> -w <value>
# Required accounts: GITHUB_TOKEN, CLAUDE_CODE_OAUTH_TOKEN
# For plane provider also: PLANE_API_KEY
keychain_service = "kbagent"

# Optional: shell command the agent must run before opening a PR. If non-empty,
# the prompt will include "Run `<validate_cmd>` — do not open a PR if it fails".
# Examples:
#   validate_cmd = "cd frontend && npx tsc --noEmit"
#   validate_cmd = "go build ./..."
validate_cmd = ""

[provider.github]
# owner/repo — auto-detected from `gh repo view` if omitted.
# repo = "kylebillemeyer/my-project"

[provider.plane]
base_url = "https://api.plane.so"
workspace_slug = "my-workspace"
project_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# State UUIDs — find these via: GET /api/v1/workspaces/<slug>/projects/<id>/states/
# Create "Spec Approved" (group: unstarted) and "Needs Input" (group: started) states in Plane.
state_backlog       = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
state_spec_approved = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
state_in_progress   = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
state_needs_input   = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
state_in_review     = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

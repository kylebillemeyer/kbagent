# Global credentials for kbagent.
# Copy to ~/.kbagent/.env and fill in values.
# Run `kbagent -f /path/to/file daemon` to override the default location.
#
# Project-specific config (repo path, worktrees dir, Plane project/states, etc.)
# belongs in kbagent.toml at the root of each target project repo.

KB_AGENT_PLANE_API_KEY=your-plane-api-key
KB_AGENT_GITHUB_TOKEN=ghp_your-github-token
KB_AGENT_CLAUDE_CODE_OAUTH_TOKEN=your-claude-oauth-token
